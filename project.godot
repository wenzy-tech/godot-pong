; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

[application]

config/name="Pong Game"
run/main_scene="res://Main.tscn"

[display]

window/size/width=800
window/stretch/mode="2d"
window/stretch/aspect="keep"

